# Maintainer: Greg Burd <greg@burd.me>
pkgname=lime-parser
pkgver=0.2.4
pkgrel=1
pkgdesc="Runtime-extensible LALR(1) parser generator"
arch=('x86_64' 'aarch64')
url="https://codeberg.org/gregburd/lime"
license=('PublicDomain')
depends=('llvm-libs')
makedepends=('meson' 'ninja' 'llvm')
# Local-tarball name: the release CI stages this file as <pkgname>-<pkgver>.tar.xz.
source=("$pkgname-$pkgver.tar.xz")
sha256sums=('SKIP')

build() {
  cd "$srcdir"
  arch-meson "$pkgname-$pkgver" build -Dllvm=auto
  meson compile -C build
}

check() {
  cd "$srcdir"
  meson test -C build --no-rebuild
}

package() {
  cd "$srcdir"
  meson install -C build --destdir "$pkgdir"
}
