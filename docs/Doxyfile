# Doxyfile for the Lime Parser Generator
# Generated for API documentation of the runtime extension framework

# -- Project settings --
PROJECT_NAME           = "Lime Parser Generator"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "Runtime-extensible LALR(1) parser with SIMD tokenization and LLVM JIT"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = api

# -- Build settings --
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO

# -- Input files --
# Include the root README as the Doxygen main page, all docs/*.md guides,
# and C headers for API extraction.
INPUT                  = ../README.md \
                         ./GETTING_STARTED.md \
                         ./CONCEPTS.md \
                         ./INTEGRATION.md \
                         ./EXAMPLES.md \
                         ./ARCHITECTURE.md \
                         ./API.md \
                         ./ALGORITHM.md \
                         ./EXTENSIONS.md \
                         ./DIAGNOSTICS.md \
                         ./PERFORMANCE.md \
                         ./EXTENSION_PERFORMANCE.md \
                         ./COMPARISON.md \
                         ./BENCHMARKS_VS_BISON.md \
                         ./MIGRATION_FROM_BISON.md \
                         ./MIGRATION_FROM_YACC.md \
                         ./JIT_ANALYSIS.md \
                         ./PARSER_PLUGIN_DESIGN.md \
                         ./LITERATE_FORMAT.md \
                         ../include/ \
                         ../src/snapshot.h
# MODULE_FORMAT.md is intentionally excluded: its list-of-backticked-
# directives near end-of-file triggers a doxygen markdown-parser bug
# ("Reached end of file while still searching closing `") that we
# could not isolate.  The file is a user-facing guide to the literate
# module format; it is reachable from the repository's README and does
# not need to appear in the Doxygen-generated API site.
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = NO
EXCLUDE_PATTERNS       = */test_* */bench/*

USE_MDFILE_AS_MAINPAGE = ../README.md

# -- Source browser --
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# -- Output format --
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_DYNAMIC_SECTIONS  = YES
HTML_INDEX_NUM_ENTRIES = 100
GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

# -- Other output formats (disabled) --
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# -- Diagrams --
HAVE_DOT               = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
GRAPHICAL_HIERARCHY    = NO

# -- Preprocessing --
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = __cplusplus \
                         _WIN32

# -- Warnings --
QUIET                  = NO
WARNINGS               = YES
# Accept the public-header docstring backlog as deferred work (tracked
# separately from the CI gate).  Disabling undocumented-compound and
# undocumented-member warnings lets us flip WARN_AS_ERROR=YES below
# while the backlog is being worked down.  When it reaches zero this
# line should flip back to YES.
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
# Fail the documentation build on doc errors (broken \ref, unclosed
# verbatim, malformed grouping) so CI catches doc-rot.  Undocumented
# items are still reported in the per-run log via the pages workflow
# but do not fail the build.
WARN_AS_ERROR          = YES

# GitHub-flavoured markdown anchor IDs: a heading "## Library Version"
# gets anchor "library-version" (lowercased, spaces-to-dashes).  The
# default (DOXYGEN) uses a hash-based scheme that breaks links from
# our own doc TOCs like `[Library Version](#library-version)`.
MARKDOWN_ID_STYLE      = GITHUB

# -- Grouping and navigation --
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

# -- Markdown and styling --
MARKDOWN_SUPPORT       = YES

# Obsolete Doxyfile tags (CLASS_DIAGRAMS, DOT_FONTNAME, DOT_FONTSIZE)
# from earlier Doxygen versions were removed -- the generator warns
# on them and picks modern defaults.
AUTOLINK_SUPPORT       = YES
TAB_SIZE               = 4
ALIASES                = "thread_safe=\par Thread Safety:^^" \
                         "ownership=\par Ownership:^^"

# -- Dot graphs (when available) --
DOT_NUM_THREADS        = 0

# -- Layout --
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = ..
STRIP_FROM_INC_PATH    = ../include/ ../src/
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

# -- Example paths --
EXAMPLE_PATH           = ../examples/
EXAMPLE_PATTERNS       = *.c *.h
EXAMPLE_RECURSIVE      = NO
