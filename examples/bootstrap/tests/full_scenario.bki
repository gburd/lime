# Full scenario: simulates a minimal bootstrap sequence
# This tests all BKI commands in a realistic sequence

# Create the pg_type catalog (bootstrap relation)
create pg_type 1247 bootstrap shared_relation rowtype_oid 71 (
  oid = oid FORCE NOT NULL,
  typname = name FORCE NOT NULL,
  typnamespace = oid FORCE NOT NULL,
  typlen = int2 FORCE NOT NULL,
  typbyval = bool FORCE NOT NULL,
  typtype = char FORCE NOT NULL
)

open pg_type

# Insert base types
insert (16 bool 11 1 t b)
insert (20 int8 11 8 t b)
insert (21 int2 11 2 t b)
insert (23 int4 11 4 t b)
insert (25 text 11 -1 f b)
insert (26 oid 11 4 t b)

close pg_type

# Create a non-bootstrap catalog
create pg_attribute 1249 rowtype_oid 75 (
  attrelid = oid FORCE NOT NULL,
  attname = name FORCE NOT NULL,
  atttypid = oid FORCE NOT NULL,
  attlen = int2 FORCE NOT NULL,
  attnum = int2 FORCE NOT NULL,
  attnotnull = bool FORCE NOT NULL,
  atthasdef = bool FORCE NULL
)

# Declare indexes
declare unique index pg_type_oid_index 2703 on pg_type using btree (oid oid_ops)

declare unique index pg_type_typname_nsp_index 2704 on pg_type using btree (typname name_ops, typnamespace oid_ops)

declare unique index pg_attribute_relid_attnam_index 2658 on pg_attribute using btree (attrelid oid_ops, attname name_ops)

declare unique index pg_attribute_relid_attnum_index 2659 on pg_attribute using btree (attrelid oid_ops, attnum int2_ops)

# Build all declared indexes
build indices
