# Build artifacts
*.o
*.a
*.out
*.so
builddir*/
build/
bin/
lib/
lime
core.*

# Generated bench parser (from bench_grammar.lime)
bench/bench_grammar.c
bench/bench_grammar.h

# Generated parser files (from .lime sources)
examples/*/*.c
examples/*/*.h
!examples/*/*.lime
!examples/*/main.c
!examples/*/main_conflicts.c
!examples/*/*_ext.c
!examples/multi_grammar_sql_json/multi.h
!examples/multi_grammar_sql_json/multi_driver.c
!examples/multi_grammar_sql_json/multi_helpers.c

# COBOL example: ship the hand-written tokenizer + state header,
# but exclude the generated parser .c/.h.
!examples/cobol/tokenize.c
!examples/cobol/tokenize.h
!examples/cobol/cobol_state.h
examples/cobol/cobol_grammar.c
examples/cobol/cobol_grammar.h
examples/cobol/cobol_grammar.out
examples/cobol/cobol_parser

# M5.1: hand-written test driver for the bootscanner port
!examples/pg_bootscanner/test_bootscanner.c
!examples/pg_bootscanner/*.lex

# Plugin-template example ships hand-written .c sources (not
# generated from .lime).  v0.5.2 added plugin_smoke.c alongside
# the existing plugin_host.c / sql_plugin.c.
!examples/plugin_template/plugin_smoke.c
!examples/plugin_template/plugin_host.c
!examples/plugin_template/sql_plugin.c

# Compiled example binaries
examples/bootstrap/boot_parser
examples/datalog/datalog_parser
examples/isolation/isol_parser
examples/jsonpath/jsonpath_parser
examples/mongodb/mongodb_parser
examples/pg/pg_tokenize
# PG example: the generated parser sources are large (3-4 MB each)
# and are deeply coupled to the PostgreSQL header tree, so they
# cannot be compiled standalone anyway.  Users regenerate via
# `make` or the meson custom_target as needed.
examples/pg/gram.c
examples/pg/gram.h
examples/pg/gram.out
examples/pg/gram_snapshot.c
examples/pg/pg_grammar.c
examples/pg/pg_grammar.h
examples/pg/pg_grammar.out
examples/pgbench/pgbench_parse
examples/replication/repl_parser
examples/syncrep/syncrep_parser
examples/xpath/xpath_parser
examples/xquery/xquery_parser
examples/calc/calc
examples/calc/calc_conflicts
examples/calc/libcalc_power.so
examples/calc/libcalc_bitwise.so

# Generated documentation
docs/api/

# Backup files
*.old

# Underscore directory (PostgreSQL test data)
_/

# Python bytecache
__pycache__/
*.pyc

# Coverage reports
coverage-report/

# Agent tool working directories
.agent/
.claude/
.kiro/
.cursor/
.memelord/
.codex/
.pi/
config/

# Agent / editor tool config dropped in the worktree
.mcp.json
opencode.json
CLAUDE.md
AGENTS.md
.cursorrules

# Out-of-tree correspondence with downstream consumers (PG team
# letter exchange, etc.).  Kept on disk while drafts are in flight,
# never committed.  These are the agent's working notes, not project
# artifacts -- the project's record of intent lives in commit
# messages, ROADMAP, and the docs/ tree.
Lime-Letter-*.txt
Lime-Reply-*.txt

# JSON example: generated parser sources + binary
examples/json/json_grammar.c
examples/json/json_grammar.h
examples/json/json_grammar.out
examples/json/json_parser
!examples/json/json.h
!examples/json/json_helpers.c
!examples/json/json_tokenize.c
!examples/json/json_tokenize.h
!examples/json/main.c

# Top-level dist tarballs from make dist
build-dist/
bench-runs/
